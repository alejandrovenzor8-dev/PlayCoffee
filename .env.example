# =============================================================================
# PlayCoffee OS — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
POSTGRES_USER=playcoffee
POSTGRES_PASSWORD=playcoffee_secret
POSTGRES_DB=playcoffee
DATABASE_URL=postgresql://playcoffee:playcoffee_secret@localhost:5432/playcoffee

# --- Redis ---
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# --- JWT ---
JWT_SECRET=change_me_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- App ---
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# --- Frontend (public) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
