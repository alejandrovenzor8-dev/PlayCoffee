# =============================================================================
# PlayCoffee OS — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
POSTGRES_USER=playcoffee
POSTGRES_PASSWORD=playcoffee_secret
POSTGRES_DB=playcoffee
DATABASE_URL=postgresql://playcoffee:playcoffee_secret@localhost:5432/playcoffee

# --- Redis ---
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# --- JWT ---
# Required by the backend. Use unique random values of 32+ characters.
# Production rejects placeholder values such as change_me* or fallback*.
JWT_SECRET=replace_with_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- App ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
BACKEND_PORT=3001
FRONTEND_PORT=3000

# --- Frontend (public) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
