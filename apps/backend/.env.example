# Backend Environment Variables
# Required at startup. Production rejects placeholder JWT values.
DATABASE_URL=postgresql://playcoffee:playcoffee_secret@localhost:5432/playcoffee
REDIS_URL=redis://:redis_secret@localhost:6379
JWT_SECRET=replace_with_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
