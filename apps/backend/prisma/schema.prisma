// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRoleEnum {
  SUPER_ADMIN
  ADMIN
  CASHIER
  WAITER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
  COMPLETED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  BLOCKED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR
  MIXED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  WASTE
  TRANSFER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ARRIVED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum ChildAccessType {
  ENTRY
  EXIT
  RENEWAL
}

// ─────────────────────────────────────────────
// Branch
// ─────────────────────────────────────────────

model Branch {
  id        String    @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  timezone  String    @default("America/Mexico_City")
  currency  String    @default("MXN")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  tableAreas     TableArea[]
  orders         Order[]
  shifts         Shift[]
  settings       Setting[]
  reservations   Reservation[]
  cameras        Camera[]
  inventoryItems InventoryItem[]
  childAccesses  ChildAccess[]
  auditLogs      AuditLog[]

  @@map("branches")
}

// ─────────────────────────────────────────────
// RBAC
// ─────────────────────────────────────────────

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id         String    @id @default(uuid())
  action     String // e.g. "create", "read", "update", "delete"
  subject    String // e.g. "Order", "Product"
  conditions Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  roles RolePermission[]

  @@unique([action, subject])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id           String       @id @default(uuid())
  branchId     String?
  email        String       @unique
  phone        String?
  firstName    String
  lastName     String
  passwordHash String
  pin          String? // 4-digit hashed PIN for quick access
  role         UserRoleEnum @default(WAITER)
  avatarUrl    String?
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  refreshToken String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  branch        Branch?        @relation(fields: [branchId], references: [id])
  roles         UserRole[]
  orders        Order[]
  shifts        Shift[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Product Catalog
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  color       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products Product[]

  @@map("categories")
}

model Product {
  id          String    @id @default(uuid())
  categoryId  String?
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  cost        Decimal?  @db.Decimal(10, 2)
  imageUrl    String?
  sku         String?   @unique
  barcode     String?   @unique
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  sortOrder   Int       @default(0)
  taxRate     Decimal   @default(0) @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  category       Category?         @relation(fields: [categoryId], references: [id])
  modifiers      ProductModifier[]
  orderItems     OrderItem[]
  inventoryItems InventoryItem[]

  @@map("products")
}

model Modifier {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @default(0) @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products           ProductModifier[]
  orderItemModifiers OrderItemModifier[]

  @@map("modifiers")
}

model ProductModifier {
  id         String   @id @default(uuid())
  productId  String
  modifierId String
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifier Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierId])
  @@map("product_modifiers")
}

// ─────────────────────────────────────────────
// Tables
// ─────────────────────────────────────────────

model TableArea {
  id          String    @id @default(uuid())
  branchId    String
  name        String
  description String?
  color       String?   @default("#3b82f6") // Hex color code
  order       Int       @default(0) // Display order
  floorPlan   Json? // SVG or JSON layout data
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  branch Branch            @relation(fields: [branchId], references: [id])
  tables RestaurantTable[]

  @@map("table_areas")
}

model RestaurantTable {
  id        String      @id @default(uuid())
  areaId    String
  number    String
  capacity  Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  posX      Float? // Position X on floor plan (pixels)
  posY      Float? // Position Y on floor plan (pixels)
  width     Float?      @default(120) // Width in pixels
  height    Float?      @default(120) // Height in pixels
  rotation  Float?      @default(0) // Rotation in degrees
  shape     String?     @default("rect") // "circle" | "rect" | "oval"
  color     String? // Custom color hex code
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  area         TableArea     @relation(fields: [areaId], references: [id])
  orders       Order[]
  reservations Reservation[]

  @@map("restaurant_tables")
}

// ─────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  branchId        String
  tableId         String?
  userId          String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  notes           String?
  subtotal        Decimal     @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  tipAmount       Decimal     @default(0) @db.Decimal(10, 2)
  isDelivery      Boolean     @default(false)
  isTakeaway      Boolean     @default(false)
  deliveryAddress String?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  branch   Branch           @relation(fields: [branchId], references: [id])
  table    RestaurantTable? @relation(fields: [tableId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@map("orders")
}

model OrderItem {
  id         String      @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int         @default(1)
  unitPrice  Decimal     @db.Decimal(10, 2)
  totalPrice Decimal     @db.Decimal(10, 2)
  notes      String?
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id])
  modifiers OrderItemModifier[]

  @@map("order_items")
}

model OrderItemModifier {
  id          String   @id @default(uuid())
  orderItemId String
  modifierId  String
  quantity    Int      @default(1)
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier  Modifier  @relation(fields: [modifierId], references: [id])

  @@map("order_item_modifiers")
}

// ─────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────

model Payment {
  id          String        @id @default(uuid())
  orderId     String
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  tipAmount   Decimal       @default(0) @db.Decimal(10, 2)
  change      Decimal?      @db.Decimal(10, 2)
  reference   String? // External transaction reference
  metadata    Json?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// Shifts
// ─────────────────────────────────────────────

model Shift {
  id             String    @id @default(uuid())
  branchId       String
  userId         String
  openingBalance Decimal   @db.Decimal(10, 2)
  closingBalance Decimal?  @db.Decimal(10, 2)
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("shifts")
}

// ─────────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────────

model InventoryItem {
  id           String    @id @default(uuid())
  branchId     String
  productId    String?
  name         String
  unit         String    @default("unit") // kg, liter, piece, etc.
  currentStock Decimal   @db.Decimal(10, 3)
  minStock     Decimal   @default(0) @db.Decimal(10, 3)
  maxStock     Decimal?  @db.Decimal(10, 3)
  costPerUnit  Decimal   @default(0) @db.Decimal(10, 2)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  branch    Branch              @relation(fields: [branchId], references: [id])
  product   Product?            @relation(fields: [productId], references: [id])
  movements InventoryMovement[]

  @@map("inventory_items")
}

model InventoryMovement {
  id              String       @id @default(uuid())
  inventoryItemId String
  type            MovementType
  quantity        Decimal      @db.Decimal(10, 3)
  previousStock   Decimal      @db.Decimal(10, 3)
  newStock        Decimal      @db.Decimal(10, 3)
  notes           String?
  reference       String?
  createdAt       DateTime     @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("inventory_movements")
}

// ─────────────────────────────────────────────
// Child Access (Play area management)
// ─────────────────────────────────────────────

model ChildAccess {
  id            String          @id @default(uuid())
  branchId      String
  childName     String
  childAge      Int?
  guardianName  String
  guardianPhone String
  entryTime     DateTime        @default(now())
  exitTime      DateTime?
  maxDuration   Int? // minutes
  braceletId    String?         @unique
  type          ChildAccessType @default(ENTRY)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("child_accesses")
}

// ─────────────────────────────────────────────
// Reservations
// ─────────────────────────────────────────────

model PartyPackage {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  maxGuests   Int
  duration    Int // minutes
  includes    Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  reservations Reservation[]

  @@map("party_packages")
}

model Reservation {
  id           String            @id @default(uuid())
  branchId     String
  tableId      String?
  packageId    String?
  contactName  String
  contactPhone String
  contactEmail String?
  partySize    Int
  reservedAt   DateTime
  duration     Int               @default(120) // minutes
  status       ReservationStatus @default(PENDING)
  occasion     String? // birthday, anniversary, etc.
  notes        String?
  deposit      Decimal?          @db.Decimal(10, 2)
  depositPaid  Boolean           @default(false)
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  branch  Branch           @relation(fields: [branchId], references: [id])
  table   RestaurantTable? @relation(fields: [tableId], references: [id])
  package PartyPackage?    @relation(fields: [packageId], references: [id])

  @@map("reservations")
}

// ─────────────────────────────────────────────
// Cameras
// ─────────────────────────────────────────────

model Camera {
  id        String    @id @default(uuid())
  branchId  String
  name      String
  rtspUrl   String
  location  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("cameras")
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// Settings
// ─────────────────────────────────────────────

model Setting {
  id        String   @id @default(uuid())
  branchId  String?
  key       String
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([branchId, key])
  @@map("settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  branchId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([branchId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
